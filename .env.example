# Copy this file to .env at the project root before running docker-compose:
#   cp .env.example .env
# Generate ENCRYPTION_KEY with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Host UID/GID (WSL / Linux) ─────────────────────────────────────────────────
# Required on WSL/Linux so containers write volumes as your user (avoids permission errors).
# Run once: echo "LOCAL_UID=$(id -u)" >> .env && echo "LOCAL_GID=$(id -g)" >> .env
LOCAL_UID=1000
LOCAL_GID=1000

# ── Required ───────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=

# ── Database ───────────────────────────────────────────────────────────────────
# Choose ONE of the two database modes below and configure it.
#
# ── Option A: Local Docker PostgreSQL (recommended for development) ────────────
# Add COMPOSE_PROFILES=local-db to start the bundled `db` container automatically
# when you run `docker compose up`. Remove or comment out this line for Option B.
#
# Optional: also enable test-dbs to start the sample PostgreSQL and MySQL
# databases pre-seeded with demo data. Omit if you don't need them.
#   COMPOSE_PROFILES=local-db,test-dbs
COMPOSE_PROFILES=local-db
#
# Password for the local `db` container (not needed for Option B).
APP_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
#
# DATABASE_URL used by the backend container.
# For Option A use the Docker service name "db" (Docker-internal DNS, not localhost).
DATABASE_URL=postgresql+asyncpg://savvina:REPLACE_WITH_STRONG_PASSWORD@db:5432/savvina_app
#
# ── Option B: External / managed PostgreSQL ────────────────────────────────────
# Comment out COMPOSE_PROFILES and APP_DB_PASSWORD above.
# Set DATABASE_URL to your provider's connection string.
# Most managed providers require SSL — append ?ssl=require if connections are refused.
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@your-managed-host.example.com:5432/savvina_app
#
# ── Running the backend locally outside Docker (both options) ──────────────────
# If you run `uvicorn` directly on the host (not via docker compose), override
# DATABASE_URL to the host-accessible address, e.g. for Option A:
# DATABASE_URL=postgresql+asyncpg://savvina:REPLACE_WITH_STRONG_PASSWORD@localhost:5434/savvina_app

# ── LLM Providers — set at least one ──────────────────────────────────────────

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# OpenAI-Compatible providers
# Groq:         https://console.groq.com
# Google Gemini: https://aistudio.google.com/apikey
# Cerebras:     https://cloud.cerebras.ai
# Mistral:      https://console.mistral.ai
# Also configurable per-connection via the UI:
# GitHub Models, HuggingFace, Together.ai, OpenRouter
GROQ_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=

# Set false only if your environment intercepts TLS with an untrusted CA.
# Applies to all LLM providers. Legacy env var OPENAI_VERIFY_SSL also accepted.
VERIFY_SSL=true

# Ollama (only needed if running Ollama locally)
# OLLAMA_BASE_URL=http://ollama:11434

# ── JWT ───────────────────────────────────────────────────────────────────────
# Required — at least 32 characters. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# ── App Settings ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json          # "json" for production (machine-parseable); use "text" for local dev (human-readable)
DEBUG=false

# ── App Port ───────────────────────────────────────────────────────────────────
# Port the app is exposed on. Used by docker-compose for the frontend container.
# Update CORS_ORIGINS and APP_URL below to match if you change this.
APP_PORT=3000

# ── CORS ───────────────────────────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]


# ── Advanced tuning ────────────────────────────────────────────────────────────
# The following settings are configurable from the Settings page UI at runtime —
# they do not need to be set here:
#   • Cache max age (days after which query-cache entries are pruned)
#   • Schema pruning (enabled/disabled, top-k tables per question)
#   • Embedding model (384-dim ONNX retrieval model used for semantic cache)

# ── Backing service credentials (used by docker-compose.yaml) ─────────────────
# Generate strong random values with:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
#
# APP_DB_PASSWORD is only required when COMPOSE_PROFILES includes local-db.
# SAMPLE_* passwords are only required when COMPOSE_PROFILES includes test-dbs.
SAMPLE_POSTGRES_PASSWORD=
SAMPLE_MYSQL_ROOT_PASSWORD=
SAMPLE_MYSQL_PASSWORD=
